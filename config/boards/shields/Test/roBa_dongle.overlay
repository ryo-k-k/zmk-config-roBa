#include <dt-bindings/zmk/matrix_transform.h>
#include "roBa.dtsi"

/ {
    chosen {
        // 物理キースキャンなしを表現するモックキースキャンを指定
        zmk,kscan = &mock_kscan;
        zmk,physical-layout = &physical_layout0;
    };

    // モックのキースキャンデバイス（物理キーなし用）
    mock_kscan: mock_kscan_0 {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        // 必須のcol-gpios,row-gpiosをダミー指定（エラー回避用）
        col-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
        row-gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
        events = <0>;
    };

    // キーマップ変換（ダミー配置 11列×4行）
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)                 RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(3,6) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(3,7) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)   RC(3,8) RC(3,9)                   RC(3,10)
        >;
    };

    // 物理レイアウト定義（transformのみ指定）
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "No Physical Keys Layout";
        transform = <&default_transform>;
    };

    // 物理入力例：トラックボール（GPIOピンは使用実態に合わせて変更）
    trackball0: trackball_0 {
        compatible = "zmk,trackball";
        gpio-a = <&xiao_d 10 GPIO_ACTIVE_HIGH>;
        gpio-b = <&xiao_d 11 GPIO_ACTIVE_HIGH>;
        gpio-btn = <&xiao_d 12 GPIO_ACTIVE_HIGH>;
        status = "okay";
    };

    // トラックボールイベントをリッスンするデバイス
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball0>;
    };
};

// ボード外部の左エンコーダー（存在する場合）
&left_encoder {
    status = "okay";
};

