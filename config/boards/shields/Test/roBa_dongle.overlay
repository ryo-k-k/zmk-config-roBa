#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,usb = &usbd;
    };

    mock_kscan: mock_kscan_0 {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};

&usbd {
    status = "okay";
};

&ble_central {
    status = "okay";
};
