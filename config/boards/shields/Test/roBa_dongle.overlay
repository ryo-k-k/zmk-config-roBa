/dts-v1/;

/ {
    chosen {
        zmk,physical-layout = &dongle_physical_layout;
    };

    dongle_physical_layout: dongle_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Dongle Layout";
        transform = <&default_transform>;
        // keysは無し
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <0>;
        rows = <0>;
        map = <>;
    };
};
