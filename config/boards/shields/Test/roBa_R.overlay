/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,behavior-reset = &reset;
        zmk,behavior-bootloader = &bootloader;
    };

    /* Trackball: PMW3610 on SPI, using chip select pin from gpio0 */
    trackball: trackball@0 {
        compatible = "pixart,pmw3610";
        reg = <0>;  /* CS pin is active-low */
        spi-max-frequency = <2000000>;

        /* 書き換え: chip select を gpio0 に変更 */
        cs-gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;

        irq-gpios = <&gpio0 3 GPIO_ACTIVE_LOW>;
    };

    behaviors {
        reset: reset {
            compatible = "zmk,behavior-reset";
        };

        bootloader: bootloader {
            compatible = "zmk,behavior-bootloader";
        };
    };
};

/* SPI 接続の定義 */
&spi0 {
    status = "okay";

    trackball: trackball@0 {
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;

        cs-gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
        irq-gpios = <&gpio0 3 GPIO_ACTIVE_LOW>;
    };
};

/* キーマトリックス定義: すべて gpio0 */
&kscan0 {
    compatible = "zmk,kscan-gpio-matrix";

    col-gpios = <&gpio0 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                <&gpio0 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                <&gpio0 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                <&gpio0 8  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;

    row-gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>,
                <&gpio0 18 GPIO_ACTIVE_HIGH>,
                <&gpio0 5  GPIO_ACTIVE_HIGH>,
                <&gpio0 4  GPIO_ACTIVE_HIGH>,
                <&gpio0 9  GPIO_ACTIVE_HIGH>;
};

